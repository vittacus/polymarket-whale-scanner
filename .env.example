# Copy this file to .env and fill in your values.
# Alerts are silently skipped when DISCORD_WEBHOOK_URL is absent — the scanner still runs and logs.

# --- Discord (optional — needed for alerts) ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_id/your_token

# --- Scanner tuning (optional) ---
SCAN_INTERVAL_SECONDS=1800   # default: 1800 (30 min)
MIN_WHALES=3                 # minimum agreeing whales to flag a signal
